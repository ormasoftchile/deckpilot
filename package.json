{
  "name": "executable-talk",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "displayName": "Deckpilot — Executable Markdown Presentations",
  "description": "Executable markdown presentations with live code demonstrations, recording, onboarding flows, and automated narration scripting. Formerly Executable Talk.",
  "version": "0.9.10",
  "publisher": "focus-space",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ormasoftchile/deckpilot.git"
  },
  "bugs": {
    "url": "https://github.com/ormasoftchile/deckpilot/issues"
  },
  "homepage": "https://github.com/ormasoftchile/deckpilot#readme",
  "icon": "resources/icon.png",
  "galleryBanner": {
    "color": "#1e1e1e",
    "theme": "dark"
  },
  "keywords": [
    "markdown slides",
    "slides",
    "presentation",
    "presentation markdown",
    "slides markdown",
    "developer presentation",
    "technical presentation",
    "live demo",
    "live coding presentation",
    "revealjs",
    "markdown presentation",
    "md slides",
    "demo slides",
    "interactive presentation"
  ],
  "engines": {
    "vscode": "^1.95.0"
  },
  "categories": [
    "Other",
    "Visualization"
  ],
  "activationEvents": [
    "onCommand:executableTalk.openPresentation",
    "onLanguage:markdown",
    "onChatParticipant:executable-talk.deck",
    "workspaceContains:**/*.deck.md"
  ],
  "main": "./out/src/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "executableTalk.openPresentation",
        "title": "Deckpilot: Start Presentation"
      },
      {
        "command": "executableTalk.closePresentation",
        "title": "Deckpilot: Stop Presentation"
      },
      {
        "command": "executableTalk.resetPresentation",
        "title": "Deckpilot: Reset Presentation"
      },
      {
        "command": "executableTalk.nextSlide",
        "title": "Deckpilot: Next Slide"
      },
      {
        "command": "executableTalk.previousSlide",
        "title": "Deckpilot: Previous Slide"
      },
      {
        "command": "executableTalk.openPresenterView",
        "title": "Deckpilot: Open Presenter View"
      },
      {
        "command": "executableTalk.validateDeck",
        "title": "Deckpilot: Validate Deck"
      },
      {
        "command": "executableTalk.goToSlide",
        "title": "Deckpilot: Go to Slide"
      },
      {
        "command": "executableTalk.saveScene",
        "title": "Deckpilot: Save Scene"
      },
      {
        "command": "executableTalk.restoreScene",
        "title": "Deckpilot: Restore Scene"
      },
      {
        "command": "executableTalk.startRecording",
        "title": "Deckpilot: Start Recording Session"
      },
      {
        "command": "executableTalk.stopRecording",
        "title": "Deckpilot: Stop Recording Session"
      },
      {
        "command": "executableTalk.pauseRecordingTiming",
        "title": "Deckpilot: Pause Recording Timing"
      },
      {
        "command": "executableTalk.resumeRecordingTiming",
        "title": "Deckpilot: Resume Recording Timing"
      },
      {
        "command": "executableTalk.toggleRecordingPause",
        "title": "Deckpilot: Toggle Recording Pause"
      },
      {
        "command": "executableTalk.markRetake",
        "title": "Deckpilot: Mark Retake Point"
      },
      {
        "command": "executableTalk.insertNarrationMarker",
        "title": "Deckpilot: Insert Narration Marker"
      },
      {
        "command": "executableTalk.autoRecord",
        "title": "Deckpilot: Auto-Record Deck"
      },
      {
        "command": "executableTalk.cancelAutoRecord",
        "title": "Deckpilot: Cancel Auto-Record"
      }
    ],
    "keybindings": [
      {
        "command": "executableTalk.goToSlide",
        "key": "ctrl+g",
        "mac": "cmd+g",
        "when": "activeWebviewPanelId == 'executableTalkPresentation'"
      },
      {
        "command": "executableTalk.saveScene",
        "key": "ctrl+s",
        "mac": "cmd+s",
        "when": "activeWebviewPanelId == 'executableTalkPresentation'"
      },
      {
        "command": "executableTalk.restoreScene",
        "key": "ctrl+r",
        "mac": "cmd+r",
        "when": "activeWebviewPanelId == 'executableTalkPresentation'"
      },
      {
        "command": "executableTalk.toggleRecordingPause",
        "key": "ctrl+shift+space",
        "mac": "cmd+shift+space",
        "when": "activeWebviewPanelId == 'executableTalkPresentation'"
      },
      {
        "command": "executableTalk.markRetake",
        "key": "ctrl+shift+r",
        "mac": "cmd+shift+r",
        "when": "activeWebviewPanelId == 'executableTalkPresentation'"
      },
      {
        "command": "executableTalk.insertNarrationMarker",
        "key": "ctrl+shift+m",
        "mac": "cmd+shift+m",
        "when": "activeWebviewPanelId == 'executableTalkPresentation'"
      }
    ],
    "chatParticipants": [
      {
        "id": "executableTalk.deck",
        "fullName": "Deck Creator",
        "name": "deck",
        "description": "Create and convert Markdown presentations into interactive Deckpilot decks",
        "isSticky": true,
        "commands": [
          {
            "name": "create",
            "description": "Create a new deck from a description (e.g., 'installation guide for Docker')"
          },
          {
            "name": "convert",
            "description": "Convert an existing Markdown file into a .deck.md presentation"
          },
          {
            "name": "enrich",
            "description": "Add voice cues, fragments, and actions to an existing deck"
          }
        ]
      }
    ],
    "languages": [
      {
        "id": "deck-markdown",
        "aliases": [
          "Deck Markdown",
          "deck.md"
        ],
        "extensions": [
          ".deck.md"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "deck-markdown",
        "scopeName": "text.html.markdown.deck",
        "path": "./syntaxes/deck-markdown.tmLanguage.json"
      }
    ],
    "configuration": {
      "title": "Deckpilot",
      "properties": {
        "executableTalk.recording.startCommand": {
          "type": "string",
          "default": "",
          "description": "Shell command to launch an external screen recorder when recording starts. Use {{outputPath}} for the video file path and {{sessionId}} for the session identifier."
        },
        "executableTalk.recording.stopCommand": {
          "type": "string",
          "default": "",
          "description": "Shell command to stop the external screen recorder when recording ends."
        },
        "executableTalk.recording.outputDir": {
          "type": "string",
          "default": "",
          "description": "Directory for recorder output files. Defaults to the deck file's directory if empty."
        },
        "executableTalk.recording.outputExtension": {
          "type": "string",
          "default": "mp4",
          "description": "File extension for the recorder output file (e.g., mp4, mkv, webm)."
        },
        "executableTalk.recording.screenDevice": {
          "type": "string",
          "default": "0:none",
          "description": "Screen device identifier for {{screenDevice}} in the start command. For avfoundation (macOS) use '0:none', '1:none', etc. For directshow (Windows) use the display name."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "lint:fix": "eslint src --ext ts --fix",
    "test": "node ./out/test/runTest.js",
    "test:unit": "mocha --require test/unit/helpers/vscode-mock.cjs --require ts-node/register 'test/unit/**/*.test.ts'",
    "test:integration": "node ./out/test/runTest.js",
    "clean": "rimraf out",
    "package": "vsce package",
    "deploy": "vsce publish",
    "version:patch": "npm version patch --no-git-tag-version",
    "version:minor": "npm version minor --no-git-tag-version",
    "version:major": "npm version major --no-git-tag-version"
  },
  "devDependencies": {
    "@types/chai": "^5.2.3",
    "@types/js-yaml": "^4.0.9",
    "@types/markdown-it": "^14.1.2",
    "@types/mocha": "^10.0.10",
    "@types/node": "^20.10.0",
    "@types/vscode": "^1.95.0",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "@vscode/test-electron": "^2.3.8",
    "@vscode/vsce": "^2.22.0",
    "chai": "^4.5.0",
    "eslint": "^8.54.0",
    "mocha": "^10.2.0",
    "prettier": "^3.1.0",
    "rimraf": "^5.0.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.2"
  },
  "dependencies": {
    "gray-matter": "^4.0.3",
    "js-yaml": "^4.1.1",
    "markdown-it": "^14.0.0"
  }
}
