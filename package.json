{
  "name": "executable-talk",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "displayName": "Deckpilot — Executable Markdown Presentations",
  "description": "Executable markdown presentations with live code demonstrations, recording, onboarding flows, and automated narration scripting. Formerly Executable Talk.",
  "version": "0.9.44",
  "publisher": "focus-space",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ormasoftchile/deckpilot.git"
  },
  "bugs": {
    "url": "https://github.com/ormasoftchile/deckpilot/issues"
  },
  "homepage": "https://github.com/ormasoftchile/deckpilot#readme",
  "icon": "resources/icon.png",
  "galleryBanner": {
    "color": "#1e1e1e",
    "theme": "dark"
  },
  "keywords": [
    "markdown slides",
    "slides",
    "presentation",
    "presentation markdown",
    "slides markdown",
    "developer presentation",
    "technical presentation",
    "live demo",
    "live coding presentation",
    "revealjs",
    "markdown presentation",
    "md slides",
    "demo slides",
    "interactive presentation"
  ],
  "engines": {
    "vscode": "^1.95.0"
  },
  "categories": [
    "Other",
    "Visualization"
  ],
  "activationEvents": [
    "onCommand:deckPilot.openPresentation",
    "onLanguage:markdown",
    "workspaceContains:**/*.deck.md"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "deckPilot.openPresentation",
        "title": "Deckpilot: Start Presentation"
      },
      {
        "command": "deckPilot.closePresentation",
        "title": "Deckpilot: Stop Presentation"
      },
      {
        "command": "deckPilot.resetPresentation",
        "title": "Deckpilot: Reset Presentation"
      },
      {
        "command": "deckPilot.nextSlide",
        "title": "Deckpilot: Next Slide"
      },
      {
        "command": "deckPilot.previousSlide",
        "title": "Deckpilot: Previous Slide"
      },
      {
        "command": "deckPilot.openPresenterView",
        "title": "Deckpilot: Open Presenter View"
      },
      {
        "command": "deckPilot.validateDeck",
        "title": "Deckpilot: Validate Deck"
      },
      {
        "command": "deckPilot.goToSlide",
        "title": "Deckpilot: Go to Slide"
      },
      {
        "command": "deckPilot.openPreview",
        "title": "Deckpilot: Open Live Preview"
      },
      {
        "command": "deckPilot.startRecording",
        "title": "Deckpilot: Start Recording Session"
      },
      {
        "command": "deckPilot.stopRecording",
        "title": "Deckpilot: Stop Recording Session"
      },
      {
        "command": "deckPilot.toggleRecordingPause",
        "title": "Deckpilot: Toggle Recording Pause"
      },
      {
        "command": "deckPilot.markRetake",
        "title": "Deckpilot: Mark Retake Point"
      },
      {
        "command": "deckPilot.autoRecord",
        "title": "Deckpilot: Auto-Record Deck"
      },
      {
        "command": "deckPilot.cancelAutoRecord",
        "title": "Deckpilot: Cancel Auto-Record"
      },
      {
        "command": "deckPilot.installAuthoringSkills",
        "title": "Deckpilot: Install Authoring Skills"
      }
    ],
    "keybindings": [
      {
        "command": "deckPilot.goToSlide",
        "key": "ctrl+g",
        "mac": "cmd+g",
        "when": "activeWebviewPanelId == 'deckPilotPresentation'"
      },
      {
        "command": "deckPilot.toggleRecordingPause",
        "key": "ctrl+shift+space",
        "mac": "cmd+shift+space",
        "when": "activeWebviewPanelId == 'deckPilotPresentation'"
      },
      {
        "command": "deckPilot.markRetake",
        "key": "ctrl+shift+r",
        "mac": "cmd+shift+r",
        "when": "activeWebviewPanelId == 'deckPilotPresentation'"
      }
    ],
    "languages": [
      {
        "id": "deck-markdown",
        "aliases": [
          "Deck Markdown",
          "deck.md"
        ],
        "extensions": [
          ".deck.md"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "deck-markdown",
        "scopeName": "text.html.markdown.deck",
        "path": "./syntaxes/deck-markdown.tmLanguage.json"
      }
    ],
    "configuration": {
      "title": "Deckpilot",
      "properties": {
        "deckPilot.recording.startCommand": {
          "type": "string",
          "default": "",
          "description": "Shell command to launch an external screen recorder when recording starts. Use {{outputPath}} for the video file path and {{sessionId}} for the session identifier."
        },
        "deckPilot.recording.stopCommand": {
          "type": "string",
          "default": "",
          "description": "Shell command to stop the external screen recorder when recording ends."
        },
        "deckPilot.recording.outputDir": {
          "type": "string",
          "default": "",
          "description": "Directory for recorder output files. Defaults to the deck file's directory if empty."
        },
        "deckPilot.recording.outputExtension": {
          "type": "string",
          "default": "mp4",
          "description": "File extension for the recorder output file (e.g., mp4, mkv, webm)."
        },
        "deckPilot.recording.screenDevice": {
          "type": "string",
          "default": "0:none",
          "description": "Screen device identifier for {{screenDevice}} in the start command. For avfoundation (macOS) use '0:none', '1:none', etc. For directshow (Windows) use the display name."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "tsc -b && npm run bundle -- --production",
    "compile": "tsc -b && npm run bundle",
    "watch": "tsc -b --watch",
    "bundle": "node esbuild.mjs",
    "bundle:watch": "node esbuild.mjs --watch",
    "lint": "eslint packages/core/src packages/extension/src --ext ts",
    "lint:fix": "eslint packages/core/src packages/extension/src --ext ts --fix",
    "test": "mocha --require test/unit/helpers/vscode-mock.cjs --require ts-node/register 'test/unit/**/*.test.ts'",
    "test:unit": "mocha --require test/unit/helpers/vscode-mock.cjs --require ts-node/register 'test/unit/**/*.test.ts'",
    "clean": "rimraf out dist packages/core/dist",
    "package": "vsce package --no-dependencies",
    "deploy": "vsce publish --no-dependencies",
    "version:patch": "npm version patch --no-git-tag-version",
    "version:minor": "npm version minor --no-git-tag-version",
    "version:major": "npm version major --no-git-tag-version"
  },
  "devDependencies": {
    "@types/chai": "^5.2.3",
    "@types/js-yaml": "^4.0.9",
    "@types/markdown-it": "^14.1.2",
    "@types/mocha": "^10.0.10",
    "@types/node": "^20.10.0",
    "@types/vscode": "^1.95.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "@vscode/test-electron": "^2.3.8",
    "@vscode/vsce": "^2.22.0",
    "chai": "^4.5.0",
    "esbuild": "^0.25.12",
    "eslint": "^8.54.0",
    "mocha": "^10.2.0",
    "prettier": "^3.1.0",
    "rimraf": "^5.0.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.2"
  },
  "dependencies": {
    "@deckpilot/core": "*",
    "js-yaml": "^4.1.1",
    "markdown-it": "^14.0.0"
  }
}
