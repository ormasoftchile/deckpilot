{
  "$schema": "https://json.schemastore.org/staticwebapp.config.json",
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": ["/assets/*", "/sample.deck.md", "/*.{css,js,svg,png,jpg,webp,ico,map,txt}"]
  },
  "mimeTypes": {
    ".deck.md": "text/markdown",
    ".deck.yaml": "application/x-yaml",
    ".md": "text/markdown",
    ".yaml": "application/x-yaml"
  },
  "globalHeaders": {
    "X-Content-Type-Options": "nosniff",
    "Referrer-Policy": "strict-origin-when-cross-origin",
    "Content-Security-Policy": "default-src 'self'; img-src 'self' https: data:; style-src 'self' 'unsafe-inline'; script-src 'self'; connect-src *; font-src 'self' data:; frame-ancestors 'none'"
  },
  "responseOverrides": {
    "404": { "rewrite": "/index.html" }
  }
}
