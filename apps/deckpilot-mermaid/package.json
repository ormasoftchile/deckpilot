{
  "name": "deckpilot-mermaid",
  "displayName": "Mermaid Diagrams for Deckpilot",
  "description": "Native Mermaid diagram renderer for Deckpilot.",
  "version": "0.12.17",
  "private": true,
  "publisher": "focus-space",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ormasoftchile/deckpilot.git"
  },
  "engines": {
    "vscode": "^1.95.0"
  },
  "categories": [
    "Other",
    "Visualization"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onLanguage:deck-markdown",
    "onLanguage:deck"
  ],
  "extensionDependencies": [
    "focus-space.executable-talk"
  ],
  "main": "./dist/extension.js",
  "scripts": {
    "compile": "npm run build",
    "bundle": "node esbuild.mjs",
    "bundle:watch": "node esbuild.mjs --watch",
    "build": "npm run bundle",
    "test": "mocha --require test/unit/helpers/vscode-mock.cjs --require ts-node/register 'test/unit/**/*.test.ts'",
    "lint": "eslint src test --ext ts"
  },
  "devDependencies": {
    "@deckpilot/core": "*",
    "@types/mocha": "^10.0.10",
    "@types/node": "^20.10.0",
    "@types/vscode": "^1.95.0",
    "esbuild": "^0.25.12",
    "eslint": "^8.54.0",
    "mocha": "^10.2.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.2"
  },
  "dependencies": {
    "jsdom": "^26.1.0",
    "mermaid": "^11.16.0"
  }
}
