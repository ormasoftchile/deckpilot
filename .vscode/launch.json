{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run Extension",
      "type": "extensionHost",
      "request": "launch",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}"
      ],
      "outFiles": [
        "${workspaceFolder}/dist/**/*.js",
        "${workspaceFolder}/out/**/*.js"
      ],
      "preLaunchTask": "build extension host"
    },
    {
      "name": "Run All Extensions (Triton + Mermaid)",
      "type": "extensionHost",
      "request": "launch",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}",
        "--extensionDevelopmentPath=${workspaceFolder}/apps/deckpilot-triton",
        "--extensionDevelopmentPath=${workspaceFolder}/apps/deckpilot-mermaid"
      ],
      "outFiles": [
        "${workspaceFolder}/dist/**/*.js",
        "${workspaceFolder}/out/**/*.js",
        "${workspaceFolder}/apps/deckpilot-triton/dist/**/*.js",
        "${workspaceFolder}/apps/deckpilot-mermaid/dist/**/*.js"
      ],
      "preLaunchTask": "build extension host"
    },
    {
      "name": "Debug Deckpilot + Triton (local Triton)",
      "type": "extensionHost",
      "request": "launch",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}",
        "--extensionDevelopmentPath=${workspaceFolder}/apps/deckpilot-triton"
      ],
      "outFiles": [
        "${workspaceFolder}/dist/**/*.js",
        "${workspaceFolder}/out/**/*.js",
        "${workspaceFolder}/apps/deckpilot-triton/dist/**/*.js",
        "${workspaceFolder}/../triton/packages/core/dist/**/*.js"
      ],
      "sourceMaps": true,
      "preLaunchTask": "build all (local triton)"
    },
    {
      "name": "Extension Tests",
      "type": "extensionHost",
      "request": "launch",
      "extensionDevelopmentPath": "${workspaceFolder}",
      "args": [
        "--extensionTestsPath=${workspaceFolder}/out/test/suite/index"
      ],
      "outFiles": [
        "${workspaceFolder}/dist/**/*.js",
        "${workspaceFolder}/out/**/*.js"
      ],
      "preLaunchTask": "build extension host"
    }
  ]
}
