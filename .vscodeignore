# Inverse-pattern .vscodeignore: ignore everything by default, then re-include
# only what the bundled extension actually ships. The extension entry is a
# single esbuild-bundled file at dist/extension.js (see esbuild.mjs); workspace
# packages, node_modules, tests, build outputs other than dist/, and the public
# web viewer are all left out of the .vsix.

# Ignore everything by default
**

# Re-include the bundled extension entry (and its source map)
!dist/extension.js
!dist/extension.js.map

# Webview assets loaded via vscode.Uri.joinPath(extensionUri, …)
!packages/extension/src/webview/assets/**

# Static assets shipped with the extension
!resources/**
!syntaxes/**
!language-configuration.json

# Marketplace metadata
!package.json
!README.md
!CHANGELOG.md
!LICENSE

# Defensive: never re-ship anything that slips through the re-includes above
**/.DS_Store
**/Thumbs.db
**/*.tsbuildinfo
**/node_modules/**
**/*.test.*
**/__tests__/**
