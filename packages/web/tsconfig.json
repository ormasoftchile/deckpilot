{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitAny": true,
    "skipLibCheck": true,
    "paths": {
      "@deckpilot/core": ["../core/src/index.ts"],
      "@deckpilot/core/*": ["../core/src/*"],
      "vscode": ["./src/stubs/vscode.ts"],
      "child_process": ["./src/stubs/child_process.ts"]
    }
  },
  "include": ["src", "vite.config.ts"],
  "exclude": ["dist", "node_modules"]
}
